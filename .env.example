# Open deze file en zet je eigen gegevens in
# (kopieer naar `.env` om te activeren)

# Publieke site-URL (gebruikt door sitemap, Open Graph, etc.)
NUXT_PUBLIC_SITE_URL=https://deguytenaerprojects.be

# Contactgegevens
NUXT_PUBLIC_CONTACT_EMAIL=info@deguytenaerprojects.be
NUXT_PUBLIC_CONTACT_PHONE=+32475435394

# Formspree / eigen endpoint voor het offerteformulier
NUXT_PUBLIC_FORMSPREE_ID=

# --- Optioneel: Unsplash API ---
# Vraag een gratis access key aan op https://unsplash.com/developers
# Laat leeg om de gecureerde catalogus (utils/unsplashCatalog.ts) te gebruiken.
NUXT_UNSPLASH_ACCESS_KEY=
